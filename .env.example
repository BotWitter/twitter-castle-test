# Copy to .env (kept out of git) or export these in your shell.

# --- Proxy ---------------------------------------------------------------
# Used for all outbound requests. The CLI also accepts a --proxy flag, which
# takes precedence over these. Supported forms (scheme defaults to http://):
#   http://user:pass@host:port
#   https://user:pass@host:port
#   socks5://user:pass@host:port
#   host:port:user:pass
#   host:port
HTTP_PROXY=
HTTPS_PROXY=

# --- Castle backend ------------------------------------------------------
# API key sent as "Authorization: Bearer <key>" to the Castle backend.
# Required by the backend; supply via this env var or the --api-key flag.
# No key is hard-coded — you must provide your own.
CASTLE_API_KEY=
